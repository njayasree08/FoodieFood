<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".PaymentActivity">

    <TextView
        android:id="@+id/tv_payment_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Method"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <RadioGroup
        android:id="@+id/rg_payment_methods"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_payment_title">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_credit_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Credit / Debit Card"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/ic_launcher_background"
            android:buttonTint="@color/primaryColor" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_upi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UPI Payment"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/ic_launcher_background"
            android:buttonTint="@color/primaryColor" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_cod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cash on Delivery"
            android:padding="16dp"
            android:background="@drawable/ic_launcher_background"
            android:buttonTint="@color/primaryColor" />
    </RadioGroup>

    <Button
        android:id="@+id/btn_pay_now"
        style="@style/ModernButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pay Now"
        android:layout_margin="24dp"
        android:backgroundTint="@color/primaryColor"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>